<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>StarForge Hub</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #0b0612;
    color: white;
    overflow-x: hidden;
}

body::before {
    content: "";
    position: fixed;
    inset: 0;
    background-image: radial-gradient(rgba(192,132,252,0.25) 1px, transparent 1px);
    background-size: 22px 22px;
    animation: move 18s linear infinite;
    z-index: -1;
}

@keyframes move {
    from { transform: translateY(0); }
    to { transform: translateY(-300px); }
}

.discord {
    width: 100%;
    background: rgba(15,8,22,0.95);
    border-bottom: 1px solid #3a1b4f;
    overflow: hidden;
    padding: 10px 0;
}

/* FIX: added padding-left so text starts off-screen properly */
.discord span {
    display: inline-block;
    white-space: nowrap;
    padding-left: 100%;
    animation: scroll 18s linear infinite;
    color: #c084fc;
    font-weight: bold;
}

@keyframes scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-100%); }
}

.container {
    max-width: 900px;
    margin: 50px auto;
    background: rgba(20,10,30,0.75);
    border: 1px solid #3a1b4f;
    border-radius: 16px;
    padding: 20px;
    backdrop-filter: blur(10px);
}

h1 {
    text-align: center;
    color: #c084fc;
    letter-spacing: 3px;
    margin-bottom: 20px;
}

.row {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
}

.box {
    flex: 1;
    min-width: 250px;
    background: rgba(15,8,22,0.85);
    border: 1px solid #3a1b4f;
    border-radius: 14px;
    padding: 15px;
}

.title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 8px;
}

.desc {
    font-size: 13px;
    color: #ccc;
    line-height: 1.5;
}

button {
    width: 100%;
    margin-top: 10px;
    padding: 10px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
    transition: opacity 0.2s;
}

button:hover {
    opacity: 0.85;
}

.purple {
    background: #c084fc;
    color: black;
}

.dark {
    background: #1f1a25;
    color: white;
    border: 1px solid #3a1b4f;
}

.script {
    margin-top: 20px;
    padding: 15px;
    border-radius: 14px;
    background: rgba(20,10,30,0.75);
    border: 1px solid #3a1b4f;
}

textarea {
    width: 100%;
    height: 70px;
    background: #0f0a16;
    border: 1px solid #3a1b4f;
    color: white;
    padding: 10px;
    border-radius: 10px;
    resize: none;
    font-family: monospace;
    font-size: 13px;
}

.copy-btn {
    margin-top: 10px;
    width: 100%;
    padding: 10px;
    background: #c084fc;
    border: none;
    border-radius: 10px;
    font-weight: bold;
    cursor: pointer;
    transition: opacity 0.2s;
}

.copy-btn:hover {
    opacity: 0.85;
}

.icon {
    display: inline-block;
    margin-right: 6px;
    animation: float 2.5s ease-in-out infinite;
}

@keyframes float {
    0%   { transform: translateY(0); }
    50%  { transform: translateY(-5px); }
    100% { transform: translateY(0); }
}

@media (max-width: 600px) {
    .container {
        margin: 15px;
        padding: 15px;
    }
}

</style>
</head>

<body>

<div class="discord">
    <span>🚀 Join Our Discord For Updates &amp; Free Keys → https://discord.gg/PUE6et7CCz 🚀</span>
</div>

<div class="container">

<h1>STARFORGE HUB</h1>

<div class="row">

    <div class="box">
        <div class="title">👑 Premium Access</div>
        <div class="desc">
            Instant premium unlock with full features and priority execution system.
        </div>
        <button class="purple" onclick="buyPremium()">Buy Premium</button>
    </div>

    <div class="box">
        <div class="title">⚡ Lootlabs Key</div>
        <div class="desc">
            Secure verification required to unlock access safely.
        </div>
        <button class="dark" onclick="getKey()">Get Key</button>
    </div>

</div>

<div class="script">

<h3>Script</h3>

<textarea id="scriptBox">loadstring(game:HttpGet("https://raw.githubusercontent.com/QeropTheeeeeee/ZyroYonkHub/refs/heads/main/ZyroYOnk"))()</textarea>

<!-- FIX: renamed class from "copy" to "copy-btn" to avoid conflicts -->
<button class="copy-btn" onclick="copyScript()">Copy Script</button>

</div>

</div>

<script>

/* FIX: renamed from copy() to copyScript() to avoid browser conflicts
   FIX: using modern navigator.clipboard API instead of deprecated execCommand */
function copyScript() {
    const text = document.getElementById("scriptBox").value;
    const btn = document.querySelector(".copy-btn");

    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(() => {
            btn.innerText = "Copied ✓";
            setTimeout(() => { btn.innerText = "Copy Script"; }, 1500);
        }).catch(() => {
            fallbackCopy(text, btn);
        });
    } else {
        fallbackCopy(text, btn);
    }
}

function fallbackCopy(text, btn) {
    const t = document.getElementById("scriptBox");
    t.select();
    t.setSelectionRange(0, 99999);
    document.execCommand("copy");
    btn.innerText = "Copied ✓";
    setTimeout(() => { btn.innerText = "Copy Script"; }, 1500);
}

function buyPremium() {
    window.open("https://roblox.com", "_blank");
}

function getKey() {
    window.location.href = "https://new.pandadevelopment.net/getkey/httpslootlinkcoms0u4sku?hwid=YOUR_HWID";
}

</script>

</body>
</html>
